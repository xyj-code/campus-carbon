





























































































































































/* ---- 整体 ---- */
.container.data-v-de840a80 {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9f0 0%, #e6f7e6 100%);
  padding: 0 0 60rpx;
}
/* ---- Banner ---- */
.banner.data-v-de840a80 {
  background: linear-gradient(135deg, #2e7d32, #43a047 60%, #66bb6a);
  padding: 60rpx 40rpx 48rpx;
  border-radius: 0 0 40rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 32rpx;
}
.banner-icon-wrap.data-v-de840a80 {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.banner-icon.data-v-de840a80 { font-size: 54rpx;
}
.banner-text.data-v-de840a80 {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.banner-title.data-v-de840a80 {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}
.banner-sub.data-v-de840a80 {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  line-height: 1.5;
}
/* ---- 卡片通用 ---- */
.card.data-v-de840a80 {
  margin: 0 28rpx 28rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(46,125,50,0.10);
}
/* ---- 输入卡片 ---- */
.card-header.data-v-de840a80 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.card-label.data-v-de840a80 {
  font-size: 28rpx;
  font-weight: bold;
  color: #2e7d32;
}
.char-count.data-v-de840a80 {
  font-size: 22rpx;
  color: #bbb;
}
/* 快捷chips */
.chips-scroll.data-v-de840a80 {
  white-space: nowrap;
  margin-bottom: 24rpx;
}
.chips-row.data-v-de840a80 {
  display: flex;
  gap: 16rpx;
  padding: 4rpx 0;
}
.chip.data-v-de840a80 {
  display: inline-flex;
  align-items: center;
  background: #f0faf0;
  border: 1rpx solid #a5d6a7;
  border-radius: 40rpx;
  padding: 10rpx 24rpx;
  flex-shrink: 0;
}
.chip-text.data-v-de840a80 {
  font-size: 22rpx;
  color: #2e7d32;
  white-space: nowrap;
}
/* 输入框 */
.textarea.data-v-de840a80 {
  width: 100%;
  min-height: 200rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 1.7;
  box-sizing: border-box;
  transition: border-color 0.2s;
  background: #fafff8;
}
.textarea.focused.data-v-de840a80 {
  border-color: #43a047;
  box-shadow: 0 0 0 4rpx rgba(67,160,71,0.12);
}
.ph.data-v-de840a80 { color: #ccc;
}
/* 按钮行 */
.btn-row.data-v-de840a80 {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}
.btn-clear.data-v-de840a80 {
  height: 88rpx;
  padding: 0 36rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.btn-clear-text.data-v-de840a80 {
  font-size: 26rpx;
  color: #999;
}
.btn-submit.data-v-de840a80 {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(90deg, #22c55e, #16a34a);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(34,197,94,0.35);
  transition: -webkit-transform 0.15s;
  transition: transform 0.15s;
  transition: transform 0.15s, -webkit-transform 0.15s;
}
.btn-submit.btn-press.data-v-de840a80 { -webkit-transform: scale(0.96); transform: scale(0.96);
}
.btn-submit.loading.data-v-de840a80 {
  background: linear-gradient(90deg, #86efac, #4ade80);
  box-shadow: none;
}
.btn-submit-text.data-v-de840a80 {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 2rpx;
}
/* Loading 点动画 */
.loading-dots.data-v-de840a80 {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.dot.data-v-de840a80 {
  font-size: 20rpx;
  color: #fff;
  -webkit-animation: blink-data-v-de840a80 1.2s infinite;
          animation: blink-data-v-de840a80 1.2s infinite;
}
.d1.data-v-de840a80 { -webkit-animation-delay: 0s; animation-delay: 0s;
}
.d2.data-v-de840a80 { -webkit-animation-delay: 0.3s; animation-delay: 0.3s;
}
.d3.data-v-de840a80 { -webkit-animation-delay: 0.6s; animation-delay: 0.6s;
}
@-webkit-keyframes blink-data-v-de840a80 {
0%, 80%, 100% { opacity: 0.2;
}
40% { opacity: 1;
}
}
@keyframes blink-data-v-de840a80 {
0%, 80%, 100% { opacity: 0.2;
}
40% { opacity: 1;
}
}
/* ---- 结果卡片 ---- */
.result-card.data-v-de840a80 {
  padding: 32rpx 32rpx 28rpx;
}
.result-header.data-v-de840a80 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.result-title-wrap.data-v-de840a80 {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.result-icon.data-v-de840a80 { font-size: 32rpx;
}
.result-title.data-v-de840a80 {
  font-size: 28rpx;
  font-weight: bold;
  color: #2e7d32;
}
.btn-copy.data-v-de840a80 {
  background: #f0faf0;
  border: 1rpx solid #a5d6a7;
  border-radius: 32rpx;
  padding: 10rpx 24rpx;
}
.copy-text.data-v-de840a80 {
  font-size: 22rpx;
  color: #43a047;
}
.divider.data-v-de840a80 {
  height: 1rpx;
  background: #f0f0f0;
  margin-bottom: 24rpx;
}
.result-scroll.data-v-de840a80 {
  max-height: 600rpx;
}
.paragraphs.data-v-de840a80 {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.para.data-v-de840a80 {
  background: #f9fef9;
  border-left: 6rpx solid #a5d6a7;
  border-radius: 0 12rpx 12rpx 0;
  padding: 20rpx 20rpx 20rpx 24rpx;
}
.para-text.data-v-de840a80 {
  font-size: 26rpx;
  color: #444;
  line-height: 1.8;
}
/* ---- 空状态 ---- */
.empty-tip.data-v-de840a80 {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 0;
  gap: 12rpx;
}
.empty-icon.data-v-de840a80 {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}
.empty-text.data-v-de840a80 {
  font-size: 26rpx;
  color: #aaa;
  text-align: center;
}

