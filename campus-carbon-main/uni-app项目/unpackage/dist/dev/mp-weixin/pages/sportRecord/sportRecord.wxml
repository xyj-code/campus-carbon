<view class="container data-v-04e142d2"><view class="decorations data-v-04e142d2"><view class="leaf leaf-1 data-v-04e142d2">🍃</view><view class="leaf leaf-2 data-v-04e142d2">🍃</view><view class="leaf leaf-3 data-v-04e142d2">🍃</view><view class="leaf leaf-4 data-v-04e142d2">🍃</view></view><view class="page-header data-v-04e142d2"><text class="header-icon data-v-04e142d2">🌞</text><text class="header-title data-v-04e142d2">运动记录</text><text class="header-icon data-v-04e142d2">🍃</text></view><view class="{{['form-section','data-v-04e142d2',(isLoaded)?'loaded':'']}}"><text class="section-title data-v-04e142d2">添加运动记录</text><text class="label data-v-04e142d2">运动类型：</text><picker range="{{sportTypes}}" value="{{sportTypeIndex}}" data-event-opts="{{[['change',[['onSportTypeChange',['$event']]]]]}}" bindchange="__e" class="data-v-04e142d2"><view class="picker data-v-04e142d2"><text class="icon-sport data-v-04e142d2">🏃</text><text class="data-v-04e142d2">{{sportTypes[sportTypeIndex]}}</text></view></picker><text class="label data-v-04e142d2">开始时间：</text><picker mode="datetime" value="{{startTime}}" data-event-opts="{{[['change',[['onStartTimeChange',['$event']]]]]}}" bindchange="__e" class="data-v-04e142d2"><view class="picker data-v-04e142d2"><text class="icon-time data-v-04e142d2">🕒</text><text class="data-v-04e142d2">{{startTime}}</text></view></picker><text class="label data-v-04e142d2">结束时间：</text><picker mode="datetime" value="{{endTime}}" data-event-opts="{{[['change',[['onEndTimeChange',['$event']]]]]}}" bindchange="__e" class="data-v-04e142d2"><view class="picker data-v-04e142d2"><text class="icon-time data-v-04e142d2">🕒</text><text class="data-v-04e142d2">{{endTime}}</text></view></picker><text class="label data-v-04e142d2">运动量（公里）：</text><view class="input-container data-v-04e142d2"><text class="icon-step data-v-04e142d2">👣</text><input class="input data-v-04e142d2" type="digit" placeholder="请输入运动距离" data-event-opts="{{[['input',[['__set_model',['','amount','$event',[]]]]]]}}" value="{{amount}}" bindinput="__e"/><text class="input-unit data-v-04e142d2">km</text></view><button class="btn primary data-v-04e142d2" loading="{{submitting}}" data-event-opts="{{[['tap',[['submitRecord',['$event']]]]]}}" bindtap="__e"><text class="btn-text data-v-04e142d2">{{submitting?'提交中...':'提交记录'}}</text></button></view><block wx:if="{{$root.g0>0}}"><view class="{{['record-section','data-v-04e142d2',(isLoaded)?'loaded':'']}}"><text class="section-title data-v-04e142d2">运动记录列表</text><view class="record-list data-v-04e142d2"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="history-item data-v-04e142d2"><view class="record-content data-v-04e142d2"><text class="record-type data-v-04e142d2">{{item.$orig.sportType}}</text><text class="record-amount data-v-04e142d2">{{item.$orig.amount+" km"}}</text><text class="record-time data-v-04e142d2">{{item.m0+" ~ "+item.m1}}</text></view></view></block></view></view></block><block wx:else><view class="{{['empty-section','data-v-04e142d2',(isLoaded)?'loaded':'']}}"><text class="empty-text data-v-04e142d2">暂无运动记录</text></view></block></view>