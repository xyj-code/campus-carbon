<view class="page data-v-f033cf78"><view class="gradient-bg data-v-f033cf78"></view><scroll-view class="scroller data-v-f033cf78" scroll-y="{{true}}" show-scrollbar="{{false}}"><view class="hero-card data-v-f033cf78"><text class="hero-kicker data-v-f033cf78">{{copy.heroKicker}}</text><text class="hero-title data-v-f033cf78">{{plan.summary.title}}</text><text class="hero-subtitle data-v-f033cf78">{{plan.summary.reason}}</text><block wx:if="{{preferenceEvidence}}"><view class="hero-preference data-v-f033cf78"><text class="hero-preference-text data-v-f033cf78">{{preferenceEvidence}}</text></view></block><view class="hero-metrics data-v-f033cf78"><view class="metric-chip data-v-f033cf78"><text class="metric-label data-v-f033cf78">{{copy.focusLabel}}</text><text class="metric-value data-v-f033cf78">{{plan.summary.focusLabel}}</text></view><view class="metric-chip data-v-f033cf78"><text class="metric-label data-v-f033cf78">{{copy.carbonLabel}}</text><text class="metric-value data-v-f033cf78">{{plan.summary.estimatedCarbonSaving+"g"}}</text></view><view class="metric-chip data-v-f033cf78"><text class="metric-label data-v-f033cf78">{{copy.pointsLabel}}</text><text class="metric-value data-v-f033cf78">{{plan.summary.estimatedPoints+" pts"}}</text></view></view><view class="hero-footer data-v-f033cf78"><text class="hero-status data-v-f033cf78">{{plan.summary.completionLabel}}</text><text class="hero-time data-v-f033cf78">{{copy.updatedLabel+" "+plan.summary.updatedAt}}</text></view></view><view class="composer-card data-v-f033cf78"><view class="section-head data-v-f033cf78"><text class="section-title data-v-f033cf78">{{copy.composerTitle}}</text><text class="section-subtitle data-v-f033cf78">{{copy.composerSubtitle}}</text></view><scroll-view class="chip-scroll data-v-f033cf78" scroll-x="{{true}}" show-scrollbar="{{false}}"><view class="chip-row data-v-f033cf78"><block wx:for="{{quickNotes}}" wx:for-item="note" wx:for-index="__i0__" wx:key="*this"><view data-event-opts="{{[['tap',[['appendQuickNote',['$0'],[[['quickNotes','',__i0__]]]]]]]}}" class="chip data-v-f033cf78" bindtap="__e"><text class="chip-text data-v-f033cf78">{{note}}</text></view></block></view></scroll-view><textarea class="note-textarea data-v-f033cf78" maxlength="{{120}}" placeholder="{{copy.notePlaceholder}}" show-confirm-bar="{{false}}" auto-height="{{true}}" data-event-opts="{{[['input',[['__set_model',['','userNote','$event',[]]]]]]}}" value="{{userNote}}" bindinput="__e"></textarea><view class="composer-actions data-v-f033cf78"><view data-event-opts="{{[['tap',[['fetchPlan',['']]]]]}}" class="ghost-btn data-v-f033cf78" bindtap="__e"><text class="ghost-btn-text data-v-f033cf78">{{copy.refreshAction}}</text></view><view data-event-opts="{{[['tap',[['submitNotePlan',['$event']]]]]}}" class="{{['primary-btn','data-v-f033cf78',(loading)?'disabled':'']}}" bindtap="__e"><text class="primary-btn-text data-v-f033cf78">{{loading?copy.loadingText:copy.generateAction}}</text></view></view></view><view class="actions-card data-v-f033cf78"><view class="section-head data-v-f033cf78"><text class="section-title data-v-f033cf78">{{copy.actionsTitle}}</text><text class="section-subtitle data-v-f033cf78">{{copy.actionsSubtitle}}</text></view><block wx:if="{{$root.g0}}"><view class="action-list data-v-f033cf78"><block wx:for="{{plan.actions}}" wx:for-item="action" wx:for-index="__i1__" wx:key="id"><view class="action-item data-v-f033cf78"><view class="action-top data-v-f033cf78"><view class="action-copy data-v-f033cf78"><text class="action-tag data-v-f033cf78">{{action.priorityTag}}</text><text class="action-title data-v-f033cf78">{{action.title}}</text><text class="action-reason data-v-f033cf78">{{action.reason}}</text></view><view class="action-points data-v-f033cf78"><text class="action-points-value data-v-f033cf78">{{"+"+action.estimatedPoints}}</text><text class="action-points-label data-v-f033cf78">pts</text></view></view><view class="action-meta data-v-f033cf78"><view class="meta-pill data-v-f033cf78"><text class="meta-pill-text data-v-f033cf78">{{action.durationMinutes+" min"}}</text></view><view class="meta-pill data-v-f033cf78"><text class="meta-pill-text data-v-f033cf78">{{action.estimatedCarbonSaving+"g CO2"}}</text></view><block wx:if="{{action.actionText}}"><view class="meta-pill data-v-f033cf78"><text class="meta-pill-text data-v-f033cf78">{{action.actionText}}</text></view></block></view><view class="action-buttons data-v-f033cf78"><view data-event-opts="{{[['tap',[['openAction',['$0'],[[['plan.actions','id',action.id]]]]]]]}}" class="ghost-btn small data-v-f033cf78" bindtap="__e"><text class="ghost-btn-text data-v-f033cf78">{{copy.openAction}}</text></view><view data-event-opts="{{[['tap',[['adoptAction',['$0'],[[['plan.actions','id',action.id]]]]]]]}}" class="primary-btn small data-v-f033cf78" bindtap="__e"><text class="primary-btn-text data-v-f033cf78">{{copy.adoptAction}}</text></view></view></view></block></view></block><block wx:else><view class="empty-card data-v-f033cf78"><text class="empty-title data-v-f033cf78">{{copy.emptyTitle}}</text><text class="empty-subtitle data-v-f033cf78">{{copy.emptySubtitle}}</text></view></block></view><block wx:if="{{$root.g1}}"><view class="evidence-card data-v-f033cf78"><view class="section-head data-v-f033cf78"><text class="section-title data-v-f033cf78">{{copy.evidenceTitle}}</text><text class="section-subtitle data-v-f033cf78">{{copy.evidenceSubtitle}}</text></view><view class="evidence-list data-v-f033cf78"><block wx:for="{{plan.evidence}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="evidence-item data-v-f033cf78"><view class="evidence-dot data-v-f033cf78"></view><text class="evidence-text data-v-f033cf78">{{item}}</text></view></block></view></view></block><view class="history-card data-v-f033cf78"><view class="section-head data-v-f033cf78"><text class="section-title data-v-f033cf78">{{copy.historyTitle}}</text><text class="section-subtitle data-v-f033cf78">{{copy.historySubtitle}}</text></view><block wx:if="{{$root.g2}}"><view class="history-list data-v-f033cf78"><block wx:for="{{adoptedHistory}}" wx:for-item="item" wx:for-index="__i2__" wx:key="id"><view class="history-item data-v-f033cf78"><view class="history-copy data-v-f033cf78"><text class="history-title data-v-f033cf78">{{item.title}}</text><text class="history-time data-v-f033cf78">{{item.adoptedAt}}</text></view><view class="history-meta data-v-f033cf78"><text class="history-meta-text data-v-f033cf78">{{item.estimatedCarbonSaving+"g"}}</text><text class="history-meta-text data-v-f033cf78">{{"+"+item.estimatedPoints+" pts"}}</text></view></view></block></view></block><block wx:else><view class="empty-card data-v-f033cf78"><text class="empty-title data-v-f033cf78">{{copy.historyEmptyTitle}}</text><text class="empty-subtitle data-v-f033cf78">{{copy.historyEmptySubtitle}}</text></view></block></view><view class="spacer data-v-f033cf78"></view></scroll-view></view>