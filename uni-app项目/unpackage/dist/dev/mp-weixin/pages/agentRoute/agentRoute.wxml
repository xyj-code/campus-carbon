<view class="page data-v-75e04674"><map class="route-map data-v-75e04674" latitude="{{centerLatitude}}" longitude="{{centerLongitude}}" markers="{{markers}}" polyline="{{polyline}}" include-points="{{includePoints}}" show-location="{{true}}"></map><view class="route-panel data-v-75e04674"><view class="panel-handle data-v-75e04674"></view><text class="route-kicker data-v-75e04674">{{copy.routeKicker}}</text><text class="route-title data-v-75e04674">{{routePlan.venueName||copy.routeTitleFallback}}</text><block wx:if="{{routePlan.venueAddress}}"><text class="route-address data-v-75e04674">{{routePlan.venueAddress}}</text></block><view class="route-metrics data-v-75e04674"><view class="metric data-v-75e04674"><text class="metric-value data-v-75e04674">{{distanceLabel}}</text><text class="metric-label data-v-75e04674">{{copy.distanceLabel}}</text></view><view class="metric data-v-75e04674"><text class="metric-value data-v-75e04674">{{durationLabel}}</text><text class="metric-label data-v-75e04674">{{copy.durationLabel}}</text></view><view class="metric data-v-75e04674"><text class="metric-value data-v-75e04674">{{routePlan.transportMode||copy.walkLabel}}</text><text class="metric-label data-v-75e04674">{{copy.modeLabel}}</text></view></view><block wx:if="{{$root.g0}}"><view class="steps-card data-v-75e04674"><text class="steps-title data-v-75e04674">{{copy.stepsTitle}}</text><block wx:for="{{routeSteps}}" wx:for-item="step" wx:for-index="index" wx:key="index"><view class="step-item data-v-75e04674"><view class="step-index data-v-75e04674"><text class="step-index-text data-v-75e04674">{{index+1}}</text></view><text class="step-text data-v-75e04674">{{step}}</text></view></block></view></block><block wx:else><view class="empty-card data-v-75e04674"><text class="empty-text data-v-75e04674">{{copy.emptyRoute}}</text></view></block></view></view>