<view class="page data-v-0eb01a14"><view class="gradient-bg data-v-0eb01a14"></view><view class="particle-system data-v-0eb01a14"><block wx:for="{{40}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="particle data-v-0eb01a14" style="{{(particleStyles[index])}}"></view></block></view><scroll-view class="scroller data-v-0eb01a14" scroll-y="true" show-scrollbar="{{false}}"><view class="carbon-card data-v-0eb01a14"><view class="carbon-header data-v-0eb01a14"><text class="carbon-label data-v-0eb01a14">当前累计减碳量</text><text class="carbon-value data-v-0eb01a14">{{totalCarbon+" kg"}}</text></view><view class="progress-section data-v-0eb01a14"><view class="progress-header data-v-0eb01a14"><text class="progress-label data-v-0eb01a14">{{"下一解锁目标："+nextGoal.name}}</text><text class="progress-percent data-v-0eb01a14">{{progressPercent+"%"}}</text></view><view class="progress-bar data-v-0eb01a14"><view class="progress-fill data-v-0eb01a14" style="{{'width:'+(progressPercent+'%')+';'}}"></view></view><view class="progress-info data-v-0eb01a14"><text class="data-v-0eb01a14">{{"还需 "+nextGoal.remaining+" kg 解锁 "+nextGoal.name}}</text></view></view></view><view class="map-card data-v-0eb01a14"><view class="map-container data-v-0eb01a14"><map class="china-map data-v-0eb01a14" longitude="{{104.20}}" latitude="{{35.86}}" scale="{{4}}" markers="{{mapMarkers}}" enable-zoom="{{true}}" enable-scroll="{{true}}" show-scale="{{true}}" data-event-opts="{{[['markertap',[['onMarkerTap',['$event']]]]]}}" bindmarkertap="__e"></map></view></view><view class="records-section data-v-0eb01a14"><text class="section-title data-v-0eb01a14">我的解锁记录</text><block wx:if="{{$root.g0>0}}"><view class="records-list data-v-0eb01a14"><block wx:for="{{userProjects}}" wx:for-item="project" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['tap',[['goToCertificate',['$0'],[[['userProjects','id',project.id,'id']]]]]]]}}" class="record-item data-v-0eb01a14" bindtap="__e"><view class="record-left data-v-0eb01a14"><view class="{{['record-icon','data-v-0eb01a14',project.projectType]}}"><block wx:if="{{project.projectType==='tree'}}"><text class="data-v-0eb01a14">🌳</text></block><block wx:else><block wx:if="{{project.projectType==='porpoise'}}"><text class="data-v-0eb01a14">🐬</text></block><block wx:else><block wx:if="{{project.projectType==='library'}}"><text class="data-v-0eb01a14">📚</text></block><block wx:else><text class="data-v-0eb01a14">🌱</text></block></block></block></view><view class="record-info data-v-0eb01a14"><text class="record-name data-v-0eb01a14">{{project.projectName}}</text><text class="record-time data-v-0eb01a14">{{project.unlockTime}}</text></view></view><view class="record-right data-v-0eb01a14"><text class="record-code data-v-0eb01a14">{{project.uniqueCode}}</text><text class="record-arrow data-v-0eb01a14">›</text></view></view></block></view></block><block wx:else><view class="empty-state data-v-0eb01a14"><text class="empty-text data-v-0eb01a14">暂无解锁记录</text><text class="empty-hint data-v-0eb01a14">继续低碳生活，解锁更多生态保护项目</text></view></block></view><block wx:if="{{showDetail}}"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="modal-overlay data-v-0eb01a14" bindtap="__e"><view class="detail-modal data-v-0eb01a14"><view class="modal-header data-v-0eb01a14"><text class="modal-title data-v-0eb01a14">{{projectDetail.name}}</text><text data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="modal-close data-v-0eb01a14" bindtap="__e">×</text></view><view class="modal-body data-v-0eb01a14"><text class="detail-location data-v-0eb01a14">{{"📍 "+projectDetail.location}}</text><text class="detail-description data-v-0eb01a14">{{projectDetail.description}}</text><block wx:if="{{$root.g1}}"><view class="detail-images data-v-0eb01a14"><swiper indicator-dots="{{true}}" indicator-color="#9CC0AC" indicator-active-color="#3D9B6D" class="data-v-0eb01a14"><block wx:for="{{$root.l0}}" wx:for-item="image" wx:for-index="index" wx:key="index"><swiper-item class="data-v-0eb01a14"><block wx:if="{{image.g2}}"><image class="detail-image data-v-0eb01a14" src="{{'./images/'+image.g3}}" mode="aspectFill"></image></block></swiper-item></block></swiper></view></block><view class="detail-progress data-v-0eb01a14"><text class="progress-label data-v-0eb01a14">项目进度</text><view class="progress-bar data-v-0eb01a14"><view class="progress-fill data-v-0eb01a14" style="{{'width:'+((projectDetail.progress||0)+'%')+';'}}"></view></view><text class="progress-value data-v-0eb01a14">{{(projectDetail.progress||0)+"%"}}</text></view><block wx:if="{{projectDetail.requiredCarbon}}"><view class="detail-require data-v-0eb01a14"><text class="require-text data-v-0eb01a14">{{"解锁需要 "+projectDetail.requiredCarbon+" kg 减碳量"}}</text></view></block></view><view class="modal-footer data-v-0eb01a14"><button data-event-opts="{{[['tap',[['e2',['$event']]]]]}}" class="btn-primary data-v-0eb01a14" bindtap="__e">关闭</button></view></view></view></block></scroll-view></view>