
.container.data-v-b237504c {
  min-height: 100vh;
  background: linear-gradient(160deg, #1b5e20 0%, #2e7d32 30%, #1565c0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰圆 */
.deco-circle.data-v-b237504c {
  position: absolute;
  border-radius: 50%;
  opacity: 0.12;
  background: #fff;
}
.c1.data-v-b237504c { width: 500rpx; height: 500rpx; top: -160rpx; right: -140rpx;
}
.c2.data-v-b237504c { width: 320rpx; height: 320rpx; bottom: 80rpx; left: -100rpx;
}
.c3.data-v-b237504c { width: 200rpx; height: 200rpx; top: 260rpx; left: 40rpx; opacity: 0.07;
}

/* Logo */
.logo-area.data-v-b237504c {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  z-index: 1;
}
.logo-ring.data-v-b237504c {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.18);
  border: 3rpx solid rgba(255,255,255,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 0 40rpx rgba(102,187,106,0.4);
}
.logo-icon.data-v-b237504c { font-size: 72rpx;
}
.app-name.data-v-b237504c {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.3);
}
.app-slogan.data-v-b237504c {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  letter-spacing: 2rpx;
}

/* 玻璃卡片 */
.glass-card.data-v-b237504c {
  width: 100%;
  background: rgba(255,255,255,0.14);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
  padding: 52rpx 44rpx 44rpx;
  box-shadow: 0 16rpx 64rpx rgba(0,0,0,0.25);
  z-index: 1;
}
.card-title.data-v-b237504c {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
  margin-bottom: 48rpx;
  letter-spacing: 2rpx;
}

/* 输入框 */
.field.data-v-b237504c {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.12);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.25);
  margin-bottom: 28rpx;
  padding: 0 24rpx;
  height: 96rpx;
}
.field-icon-wrap.data-v-b237504c {
  margin-right: 20rpx;
  display: flex;
  align-items: center;
}
.field-icon.data-v-b237504c { font-size: 36rpx;
}
.field-input.data-v-b237504c {
  flex: 1;
  height: 96rpx;
  font-size: 28rpx;
  color: #fff;
  background: transparent;
}
.ph.data-v-b237504c { color: rgba(255,255,255,0.45);
}

/* 登录按钮 */
.btn-sign.data-v-b237504c {
  width: 100%;
  height: 96rpx;
  margin-top: 20rpx;
  background: linear-gradient(90deg, #66bb6a, #43a047);
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(67,160,71,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-sign[disabled].data-v-b237504c {
  background: rgba(102,187,106,0.4);
  box-shadow: none;
}
.btn-text.data-v-b237504c {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
}
.hint-row.data-v-b237504c {
  text-align: center;
  margin-top: 28rpx;
}
.hint-text.data-v-b237504c {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
}

/* 底部 */
.bottom-tip.data-v-b237504c {
  margin-top: 48rpx;
  z-index: 1;
}
.bottom-text.data-v-b237504c {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  letter-spacing: 2rpx;
}

