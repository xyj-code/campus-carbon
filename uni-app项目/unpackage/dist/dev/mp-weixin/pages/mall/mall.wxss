
.container.data-v-2e142186 {
  min-height: 100vh;
  background: #f0f7f0;
  padding: 0 0 100rpx;
}

/* 顶部余额 */
.balance-banner.data-v-2e142186 {
  background: linear-gradient(160deg, #1b5e20, #4caf50);
  padding: 48rpx 40rpx 40rpx;
}
.balance-inner.data-v-2e142186 { display: flex; align-items: baseline; gap: 8rpx; margin-bottom: 12rpx;
}
.b-label.data-v-2e142186 { font-size: 28rpx; color: rgba(255,255,255,0.8); margin-right: 8rpx;
}
.b-value.data-v-2e142186 { font-size: 72rpx; font-weight: bold; color: #fff; line-height: 1;
}
.b-unit.data-v-2e142186 { font-size: 28rpx; color: rgba(255,255,255,0.85);
}
.b-tip.data-v-2e142186 { font-size: 24rpx; color: rgba(255,255,255,0.7);
}
.section-title.data-v-2e142186 {
  font-size: 30rpx;
  font-weight: bold;
  color: #2e7d32;
  padding: 32rpx 30rpx 16rpx;
}

/* 商品网格 */
.goods-grid.data-v-2e142186 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 30rpx;
}
.goods-card.data-v-2e142186 {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  position: relative;
  overflow: hidden;
}
.goods-card.out-stock.data-v-2e142186 { opacity: 0.6;
}
.goods-img.data-v-2e142186 { display: block; font-size: 72rpx; margin-bottom: 12rpx;
}
.goods-name.data-v-2e142186 { display: block; font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 8rpx;
}
.goods-desc.data-v-2e142186 { display: block; font-size: 22rpx; color: #888; line-height: 1.5; margin-bottom: 16rpx;
  overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.goods-footer.data-v-2e142186 { display: flex; align-items: center; justify-content: space-between;
}
.goods-point-wrap.data-v-2e142186 { display: flex; align-items: baseline; gap: 4rpx;
}
.goods-point.data-v-2e142186 { font-size: 36rpx; font-weight: bold; color: #e65100;
}
.goods-unit.data-v-2e142186 { font-size: 22rpx; color: #e65100;
}
.goods-stock-badge.data-v-2e142186 {
  font-size: 20rpx;
  color: #888;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}
.goods-stock-badge.low.data-v-2e142186 { background: #fff3e0; color: #e65100;
}
.sold-out-mask.data-v-2e142186 {
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #999;
}

/* 兑换记录 */
.exchange-list.data-v-2e142186 {
  background: #fff;
  margin: 0 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.ex-item.data-v-2e142186 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.ex-item.data-v-2e142186:last-child { border-bottom: none;
}
.ex-left.data-v-2e142186 { display: flex; align-items: center; gap: 16rpx;
}
.ex-icon.data-v-2e142186 { font-size: 40rpx;
}
.ex-name.data-v-2e142186 { display: block; font-size: 28rpx; color: #333;
}
.ex-time.data-v-2e142186 { display: block; font-size: 20rpx; color: #bbb; margin-top: 4rpx;
}
.ex-point.data-v-2e142186 { font-size: 28rpx; font-weight: bold; color: #999;
}
.empty-hint.data-v-2e142186 { padding: 48rpx; text-align: center; color: #aaa; font-size: 26rpx;
}
.load-more-row.data-v-2e142186 { text-align: center; padding: 24rpx;
}
.load-more-btn.data-v-2e142186 {
  background: #e8f5e9;
  color: #2e7d32;
  border: none;
  border-radius: 20rpx;
  font-size: 26rpx;
  padding: 14rpx 48rpx;
}

/* 确认弹窗 */
.modal-overlay.data-v-2e142186 {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.confirm-sheet.data-v-2e142186 {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 40rpx;
  width: 580rpx;
  text-align: center;
}
.conf-icon.data-v-2e142186 { font-size: 96rpx; display: block; margin-bottom: 16rpx;
}
.conf-name.data-v-2e142186 { display: block; font-size: 36rpx; font-weight: bold; color: #1b5e20; margin-bottom: 8rpx;
}
.conf-desc.data-v-2e142186 { display: block; font-size: 24rpx; color: #888; margin-bottom: 28rpx; line-height: 1.6;
}
.conf-points-row.data-v-2e142186 {
  background: #f9fef9;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.conf-cost.data-v-2e142186 { display: block; font-size: 36rpx; font-weight: bold; color: #e65100; margin-bottom: 8rpx;
}
.conf-remain.data-v-2e142186 { display: block; font-size: 24rpx; color: #888;
}
.conf-warn.data-v-2e142186 { background: #fff3e0; border-radius: 12rpx; padding: 16rpx; margin-bottom: 16rpx; color: #e65100; font-size: 26rpx;
}
.conf-btns.data-v-2e142186 { display: flex; gap: 20rpx; margin-top: 20rpx;
}
.conf-cancel.data-v-2e142186 {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 24rpx 0;
}
.conf-ok.data-v-2e142186 {
  flex: 1;
  background: linear-gradient(90deg, #4caf50, #2e7d32);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 24rpx 0;
}
.conf-ok.data-v-2e142186:disabled {
  background: #ccc;
  color: #fff;
}

