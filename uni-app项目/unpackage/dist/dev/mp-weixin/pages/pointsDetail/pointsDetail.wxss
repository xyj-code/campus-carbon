}
@-webkit-keyframes floatUp-data-v-bd4bcef4 {
0% {
    -webkit-transform: translateY(100vh);
            transform: translateY(100vh);
    opacity: 0;
}
10% {
    opacity: 0.8;
}
90% {
    opacity: 0.5;
}
100% {
    -webkit-transform: translateY(-20vh);
            transform: translateY(-20vh);
    opacity: 0;
}
}
@keyframes floatUp-data-v-bd4bcef4 {
0% {
    -webkit-transform: translateY(100vh);
            transform: translateY(100vh);
    opacity: 0;
}
10% {
    opacity: 0.8;
