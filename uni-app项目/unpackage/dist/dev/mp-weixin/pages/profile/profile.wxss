
.container.data-v-60cb334c {
  min-height: 100vh;
  background: #f0f7f0;
  padding-bottom: 80rpx;
}

/* Header Banner */
.header-banner.data-v-60cb334c {
  background: linear-gradient(160deg, #2e7d32, #66bb6a);
  padding: 60rpx 40rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar-wrap.data-v-60cb334c {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  border: 4rpx solid rgba(255,255,255,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}
.avatar-text.data-v-60cb334c {
  font-size: 56rpx;
  color: #fff;
  font-weight: bold;
}
.user-name.data-v-60cb334c {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}
.user-id.data-v-60cb334c {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
}

/* Overview */
.overview-card.data-v-60cb334c {
  background: #fff;
  margin: -32rpx 30rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx 20rpx;
  display: flex;
  box-shadow: 0 4rpx 20rpx rgba(46,125,50,0.1);
}
.overview-item.data-v-60cb334c {
  flex: 1;
  text-align: center;
}
.ov-sep.data-v-60cb334c {
  width: 1rpx;
  background: #e8f5e9;
  margin: 8rpx 0;
}
.ov-value.data-v-60cb334c {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}
.ov-value.green.data-v-60cb334c { color: #2e7d32;
}
.ov-label.data-v-60cb334c {
  font-size: 22rpx;
  color: #888;
}

/* Function List */
.func-list.data-v-60cb334c {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 30rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  overflow: hidden;
}
.func-item.data-v-60cb334c {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.func-item.last.data-v-60cb334c { border-bottom: none;
}
.func-left.data-v-60cb334c {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.func-icon-wrap.data-v-60cb334c {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.func-icon-wrap.tree.data-v-60cb334c { background: #e8f5e9;
}
.func-icon-wrap.star.data-v-60cb334c { background: #fff8e1;
}
.func-icon-wrap.leaf.data-v-60cb334c { background: #e8f5e9;
}
.func-icon-wrap.gear.data-v-60cb334c { background: #e3f2fd;
}
.func-icon-wrap.info.data-v-60cb334c { background: #f3e5f5;
}
.func-icon.data-v-60cb334c { font-size: 32rpx;
}
.func-text.data-v-60cb334c {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}
.func-arrow.data-v-60cb334c {
  font-size: 36rpx;
  color: #bbb;
}

/* Logout */
.logout-btn.data-v-60cb334c {
  margin: 0 30rpx;
  background: #fff;
  color: #e53935;
  border: 2rpx solid #ffcdd2;
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 24rpx;
}

/* Modal */
.modal-overlay.data-v-60cb334c {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}
.modal-sheet.data-v-60cb334c {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 40rpx 60rpx;
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
}
.modal-header.data-v-60cb334c {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}
.modal-title.data-v-60cb334c { font-size: 34rpx; font-weight: bold; color: #1b5e20;
}
.modal-close.data-v-60cb334c { font-size: 36rpx; color: #999; padding: 8rpx;
}

/* 碳账本 */
.ledger-total.data-v-60cb334c {
  text-align: center;
  padding: 24rpx 0 32rpx;
  background: linear-gradient(135deg, #e8f5e9, #f1f8e9);
  border-radius: 20rpx;
  margin-bottom: 32rpx;
}
.ledger-kg.data-v-60cb334c { font-size: 72rpx; font-weight: bold; color: #2e7d32;
}
.ledger-unit.data-v-60cb334c { font-size: 28rpx; color: #4caf50; margin-left: 8rpx;
}
.ledger-sub.data-v-60cb334c { display: block; font-size: 24rpx; color: #888; margin-top: 8rpx;
}
.equiv-row.data-v-60cb334c { display: flex; gap: 20rpx; margin-bottom: 32rpx;
}
.equiv-item.data-v-60cb334c {
  flex: 1;
  background: #f9fef9;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
}
.equiv-icon.data-v-60cb334c { display: block; font-size: 48rpx; margin-bottom: 8rpx;
}
.equiv-val.data-v-60cb334c { display: block; font-size: 36rpx; font-weight: bold; color: #2e7d32;
}
.equiv-desc.data-v-60cb334c { display: block; font-size: 20rpx; color: #888; margin-top: 4rpx;
}
.ledger-section-title.data-v-60cb334c { font-size: 26rpx; color: #555; margin-bottom: 20rpx; font-weight: 500;
}
.week-bars.data-v-60cb334c { display: flex; gap: 8rpx; align-items: flex-end;
}
.bar-col.data-v-60cb334c { flex: 1; display: flex; flex-direction: column; align-items: center;
}
.bar-wrap.data-v-60cb334c { width: 100%; height: 100rpx; display: flex; align-items: flex-end; justify-content: center;
}
.bar-fill.data-v-60cb334c { width: 24rpx; background: linear-gradient(180deg, #4caf50, #a5d6a7); border-radius: 4rpx 4rpx 0 0; min-height: 8rpx;
}
.bar-label.data-v-60cb334c { font-size: 20rpx; color: #888; margin-top: 6rpx;
}
.bar-steps.data-v-60cb334c { font-size: 18rpx; color: #2e7d32;
}

/* 设置 */
.setting-group.data-v-60cb334c { margin-bottom: 28rpx;
}
.setting-group-title.data-v-60cb334c { font-size: 24rpx; color: #888; margin-bottom: 12rpx; padding-left: 4rpx;
}
.setting-row.data-v-60cb334c {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.setting-label.data-v-60cb334c { font-size: 28rpx; color: #333;
}
.setting-value.data-v-60cb334c { font-size: 26rpx; color: #888;
}
.setting-input.data-v-60cb334c {
  font-size: 26rpx;
  color: #333;
  text-align: right;
  width: 300rpx;
  border: none;
  background: transparent;
}
.save-name-btn.data-v-60cb334c {
  margin-top: 16rpx;
  background: linear-gradient(90deg, #4caf50, #2e7d32);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 26rpx;
  padding: 18rpx;
}
.clear-cache-btn.data-v-60cb334c {
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 12rpx;
  font-size: 26rpx;
  padding: 20rpx;
}

/* 关于 */
