}
.about-appname.data-v-60cb334c { display: block; text-align: center; font-size: 36rpx; font-weight: bold; color: #1b5e20; margin-bottom: 8rpx;
}
.about-version.data-v-60cb334c { display: block; text-align: center; font-size: 24rpx; color: #999; margin-bottom: 24rpx;
}
.about-desc.data-v-60cb334c { display: block; text-align: center; font-size: 26rpx; color: #555; line-height: 1.7; margin-bottom: 28rpx; padding: 0 8rpx;
}
.about-divider.data-v-60cb334c { height: 1rpx; background: #f0f0f0; margin-bottom: 16rpx;
}
.about-row.data-v-60cb334c {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
