<view class="container data-v-4fd5f848"><view class="nav-bar data-v-4fd5f848"><text data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="nav-back data-v-4fd5f848" bindtap="__e">←</text><text class="nav-title data-v-4fd5f848">项目详情</text></view><block wx:if="{{projectDetail}}"><view class="project-section data-v-4fd5f848"><view class="project-header data-v-4fd5f848"><text class="project-name data-v-4fd5f848">{{projectDetail.name}}</text><text class="project-location data-v-4fd5f848">{{projectDetail.location}}</text></view><view class="project-info data-v-4fd5f848"><text class="info-title data-v-4fd5f848">项目介绍</text><text class="info-content data-v-4fd5f848">{{projectDetail.description}}</text></view><view class="project-progress data-v-4fd5f848"><text class="progress-title data-v-4fd5f848">项目进度</text><view class="progress-bar data-v-4fd5f848"><view class="progress-fill data-v-4fd5f848" style="{{'width:'+(projectDetail.progress+'%')+';'}}"></view></view><text class="progress-value data-v-4fd5f848">{{projectDetail.progress+"%"}}</text></view><block wx:if="{{$root.g0}}"><view class="project-images data-v-4fd5f848"><text class="images-title data-v-4fd5f848">项目实拍</text><view class="images-grid data-v-4fd5f848"><block wx:for="{{projectDetail.images}}" wx:for-item="img" wx:for-index="index" wx:key="index"><image class="image-item data-v-4fd5f848" src="{{img}}" mode="aspectFill" data-event-opts="{{[['tap',[['previewImage',['$0','$1'],[[['projectDetail.images','',index]],'projectDetail.images']]]]]}}" bindtap="__e"></image></block></view></view></block><view class="unlock-condition data-v-4fd5f848"><text class="condition-title data-v-4fd5f848">解锁条件</text><text class="condition-content data-v-4fd5f848">{{"累计减碳 "+$root.m0+" kg"}}</text></view></view></block><block wx:else><view class="loading-state data-v-4fd5f848"><text class="loading-text data-v-4fd5f848">加载中...</text></view></block></view>