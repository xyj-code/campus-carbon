<view class="page data-v-f8d83f34"><scroll-view class="scroller data-v-f8d83f34" scroll-y="{{true}}" show-scrollbar="{{false}}"><view class="header data-v-f8d83f34"><text class="header-kicker data-v-f8d83f34">{{copy.kicker}}</text><text class="header-title data-v-f8d83f34">{{copy.title}}</text><text class="header-subtitle data-v-f8d83f34">{{copy.subtitle}}</text></view><view class="form-card data-v-f8d83f34"><view class="form-row data-v-f8d83f34"><text class="label data-v-f8d83f34">{{copy.weekdayLabel}}</text><picker range="{{weekdayOptions}}" range-key="label" value="{{weekdayIndex}}" data-event-opts="{{[['change',[['onWeekdayChange',['$event']]]]]}}" bindchange="__e" class="data-v-f8d83f34"><view class="picker-box data-v-f8d83f34">{{weekdayOptions[weekdayIndex].label}}</view></picker></view><view class="form-row data-v-f8d83f34"><text class="label data-v-f8d83f34">{{copy.courseLabel}}</text><input class="input data-v-f8d83f34" placeholder="{{copy.coursePlaceholder}}" data-event-opts="{{[['input',[['__set_model',['$0','courseName','$event',[]],['form']]]]]}}" value="{{form.courseName}}" bindinput="__e"/></view><view class="form-row data-v-f8d83f34"><text class="label data-v-f8d83f34">{{copy.locationLabel}}</text><input class="input data-v-f8d83f34" placeholder="{{copy.locationPlaceholder}}" data-event-opts="{{[['input',[['__set_model',['$0','location','$event',[]],['form']]]]]}}" value="{{form.location}}" bindinput="__e"/></view><view class="time-grid data-v-f8d83f34"><view class="time-field data-v-f8d83f34"><text class="label data-v-f8d83f34">{{copy.startLabel}}</text><picker mode="time" value="{{form.startTime}}" data-event-opts="{{[['change',[['onStartTimeChange',['$event']]]]]}}" bindchange="__e" class="data-v-f8d83f34"><view class="picker-box data-v-f8d83f34">{{form.startTime}}</view></picker></view><view class="time-field data-v-f8d83f34"><text class="label data-v-f8d83f34">{{copy.endLabel}}</text><picker mode="time" value="{{form.endTime}}" data-event-opts="{{[['change',[['onEndTimeChange',['$event']]]]]}}" bindchange="__e" class="data-v-f8d83f34"><view class="picker-box data-v-f8d83f34">{{form.endTime}}</view></picker></view></view><view data-event-opts="{{[['tap',[['submitSchedule',['$event']]]]]}}" class="{{['primary-btn','data-v-f8d83f34',(submitting)?'disabled':'']}}" bindtap="__e"><text class="primary-btn-text data-v-f8d83f34">{{form.id?copy.updateAction:copy.addAction}}</text></view><block wx:if="{{form.id}}"><view data-event-opts="{{[['tap',[['resetForm',['$event']]]]]}}" class="ghost-btn data-v-f8d83f34" bindtap="__e"><text class="ghost-btn-text data-v-f8d83f34">{{copy.cancelEdit}}</text></view></block></view><block wx:if="{{context}}"><view class="context-card data-v-f8d83f34"><view class="context-head data-v-f8d83f34"><text class="context-tag data-v-f8d83f34">{{context.stateLabel||copy.contextFallback}}</text><text class="context-count data-v-f8d83f34">{{(context.todayCourseCount||0)+" "+copy.courseCountUnit}}</text></view><text class="context-title data-v-f8d83f34">{{contextTitle}}</text><text class="context-reason data-v-f8d83f34">{{context.recommendation}}</text></view></block><view class="list-card data-v-f8d83f34"><view class="list-head data-v-f8d83f34"><text class="list-title data-v-f8d83f34">{{copy.listTitle}}</text><text class="list-count data-v-f8d83f34">{{$root.g0}}</text></view><block wx:if="{{!$root.g1}}"><view class="empty data-v-f8d83f34"><text class="empty-text data-v-f8d83f34">{{copy.emptyText}}</text></view></block><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="schedule-item data-v-f8d83f34"><view data-event-opts="{{[['tap',[['editSchedule',['$0'],[[['scheduleList','id',item.$orig.id]]]]]]]}}" class="item-main data-v-f8d83f34" bindtap="__e"><text class="item-weekday data-v-f8d83f34">{{item.m0}}</text><text class="item-title data-v-f8d83f34">{{item.$orig.courseName}}</text><text class="item-meta data-v-f8d83f34">{{item.$orig.startTime+" - "+item.$orig.endTime+" "+copy.metaSeparator+" "+(item.$orig.location||copy.noLocation)}}</text></view><view data-event-opts="{{[['tap',[['removeSchedule',['$0'],[[['scheduleList','id',item.$orig.id]]]]]]]}}" class="delete-btn data-v-f8d83f34" bindtap="__e"><text class="delete-text data-v-f8d83f34">{{copy.deleteAction}}</text></view></view></block></view><view class="spacer data-v-f8d83f34"></view></scroll-view></view>