<view class="container data-v-04e142d2"><view class="form-section data-v-04e142d2"><text class="section-title data-v-04e142d2">添加运动记录</text><text class="label data-v-04e142d2">运动类型：</text><picker range="{{sportTypes}}" value="{{sportTypeIndex}}" data-event-opts="{{[['change',[['onSportTypeChange',['$event']]]]]}}" bindchange="__e" class="data-v-04e142d2"><view class="picker data-v-04e142d2">{{sportTypes[sportTypeIndex]}}</view></picker><text class="label data-v-04e142d2">开始时间：</text><picker mode="datetime" value="{{startTime}}" data-event-opts="{{[['change',[['onStartTimeChange',['$event']]]]]}}" bindchange="__e" class="data-v-04e142d2"><view class="picker data-v-04e142d2">{{startTime}}</view></picker><text class="label data-v-04e142d2">结束时间：</text><picker mode="datetime" value="{{endTime}}" data-event-opts="{{[['change',[['onEndTimeChange',['$event']]]]]}}" bindchange="__e" class="data-v-04e142d2"><view class="picker data-v-04e142d2">{{endTime}}</view></picker><text class="label data-v-04e142d2">运动量（公里）：</text><input class="input data-v-04e142d2" type="digit" placeholder="请输入运动距离" data-event-opts="{{[['input',[['__set_model',['','amount','$event',[]]]]]]}}" value="{{amount}}" bindinput="__e"/><button class="btn data-v-04e142d2" disabled="{{submitting}}" data-event-opts="{{[['tap',[['submitRecord',['$event']]]]]}}" bindtap="__e">{{''+(submitting?'提交中...':'提交记录')+''}}</button></view><view class="record-section data-v-04e142d2"><text class="section-title data-v-04e142d2">运动记录列表</text><block wx:if="{{$root.g0>0}}"><view class="data-v-04e142d2"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="record-item data-v-04e142d2"><view class="record-row data-v-04e142d2"><text class="record-type data-v-04e142d2">{{item.$orig.sportType}}</text><text class="record-amount data-v-04e142d2">{{item.$orig.amount+" km"}}</text></view><view class="record-row data-v-04e142d2"><text class="record-time data-v-04e142d2">{{item.m0+" ~ "+item.m1}}</text></view></view></block></view></block><block wx:else><view class="empty-section data-v-04e142d2"><text class="empty-text data-v-04e142d2">暂无运动记录</text></view></block></view></view>