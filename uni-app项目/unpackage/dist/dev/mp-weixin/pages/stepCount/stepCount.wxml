<view class="container data-v-3fb2e5ce"><view class="date-section data-v-3fb2e5ce"><text class="label data-v-3fb2e5ce">选择日期：</text><picker mode="date" value="{{date}}" data-event-opts="{{[['change',[['onDateChange',['$event']]]]]}}" bindchange="__e" class="data-v-3fb2e5ce"><view class="picker data-v-3fb2e5ce">{{date}}</view></picker><button data-event-opts="{{[['tap',[['queryStepCount',['$event']]]]]}}" class="btn data-v-3fb2e5ce" bindtap="__e">查询步数</button></view><block wx:if="{{stepData}}"><view class="step-section data-v-3fb2e5ce"><text class="step-title data-v-3fb2e5ce">步数统计</text><view class="step-info data-v-3fb2e5ce"><view class="step-item data-v-3fb2e5ce"><text class="step-label data-v-3fb2e5ce">步数：</text><text class="step-value data-v-3fb2e5ce">{{(stepData.steps||0)+" 步"}}</text></view><view class="step-item data-v-3fb2e5ce"><text class="step-label data-v-3fb2e5ce">卡路里：</text><text class="step-value data-v-3fb2e5ce">{{(stepData.calories||0)+" kcal"}}</text></view><view class="step-item data-v-3fb2e5ce"><text class="step-label data-v-3fb2e5ce">运动时长：</text><text class="step-value data-v-3fb2e5ce">{{(stepData.duration||0)+" 分钟"}}</text></view></view></view></block><block wx:if="{{queried&&!stepData}}"><view class="empty-section data-v-3fb2e5ce"><text class="empty-text data-v-3fb2e5ce">该日期暂无步数记录</text></view></block><view class="record-section data-v-3fb2e5ce"><text class="record-title data-v-3fb2e5ce">近期步数记录</text><block wx:if="{{$root.g0>0}}"><view class="data-v-3fb2e5ce"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="history-item data-v-3fb2e5ce"><text class="history-date data-v-3fb2e5ce">{{item.m0}}</text><text class="history-steps data-v-3fb2e5ce">{{item.$orig.steps+" 步"}}</text></view></block></view></block><block wx:else><view class="empty-section data-v-3fb2e5ce"><text class="empty-text data-v-3fb2e5ce">暂无历史记录</text></view></block></view></view>